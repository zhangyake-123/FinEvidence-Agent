# FinEvidence LLM settings.
# Copy this file to .env and fill in your own provider/model/key.

# Keep rule mode as the default deterministic pipeline.
FINEVIDENCE_REPORT_MODE=rule

# Options: openai, openai_compatible, litellm
FINEVIDENCE_LLM_PROVIDER=openai_compatible

# Model name depends on the selected provider.
FINEVIDENCE_LLM_MODEL=deepseek-chat

# Preferred project-specific API key variable.
FINEVIDENCE_LLM_API_KEY=

# Required for openai_compatible providers, such as DeepSeek, Qwen, Moonshot,
# Ollama, or vLLM endpoints.
FINEVIDENCE_LLM_BASE_URL=https://api.deepseek.com/v1

# Options: json_object, prompt_only
FINEVIDENCE_LLM_JSON_MODE=json_object

# Optional output token budget for LLM report generation.
FINEVIDENCE_LLM_MAX_OUTPUT_TOKENS=1600
